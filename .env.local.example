# Firebase Web App config (Firebase Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Realtime Database URL (ortak canlı tuval için)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Firebase Cloud Messaging → Web Push certificates → "Key pair" (VAPID public key)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Comma-separated list of the 2 allowed user UIDs (after they sign in once)
# e.g. NEXT_PUBLIC_ALLOWED_UIDS=abc123,def456
NEXT_PUBLIC_ALLOWED_UIDS=

# Spotify Developer App Client ID (anılar → şarkı kırpma özelliği için)
# 1. developer.spotify.com/dashboard → Create app
# 2. Redirect URIs olarak şu ikisini kaydet:
#      http://127.0.0.1:3000/auth/spotify/callback   (dev)
#      https://<your-domain>/auth/spotify/callback   (prod)
# 3. APIs: Web API + Web Playback SDK seç
# 4. User Management → her iki kullanıcının Spotify e-mail'ini ekle
# 5. Settings → Client ID'yi buraya kopyala (Client Secret'a gerek YOK — PKCE)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
